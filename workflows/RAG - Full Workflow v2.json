    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n    const mdContent = item.json.document?.md_content || item.json.md_content || \"\";\n\n    // Regex to match markdown image syntax: ![alt](filename)\n    const imageRegex = /!\\[.*?\\]\\((.*?)\\)/g;\n    const imageNames = [];\n\n    let match;\n    while ((match = imageRegex.exec(mdContent)) !== null) {\n        const filename = match[1].split('/').pop();\n        imageNames.push(filename);\n    }\n\n    item.json.imageNames = imageNames;\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
